<?php

use Drupal\Core\Datetime\DrupalDateTime;
use Drupal\user\Entity\User;
use Drupal\Core\Form\FormStateInterface;

/**
 * Implements hook_cron().
 *
 * @throws \Drupal\Core\Entity\EntityStorageException
 */
function christes_cron() {
  // Build Drupal DateTime & set correct format for your query
  $current_time = new DrupalDateTime('now');
  $current_time = $current_time->format('Y-m-d');

  // Trova il TID del termine cercando per nome
  $term_name = 'Tempo determinato'; // Sostituisci con il nome effettivo
  $vocabulary_id = 'tipologia_incarichi'; // ID del vocabolario

  $term_storage = \Drupal::entityTypeManager()->getStorage('taxonomy_term');
  $terms = $term_storage->loadByProperties([
    'name' => $term_name,
    'vid' => $vocabulary_id,
  ]);

  // Se non trovi il termine, esci
  if (empty($terms)) {
    \Drupal::logger('christes')
      ->warning('Termine tassonomico "@name" non trovato.', ['@name' => $term_name]);
    return;
  }

  // Prendi il primo termine trovato
  $term = reset($terms);
  $tid = $term->id();

  $storage = \Drupal::entityTypeManager()->getStorage('user');

  // Get all Users satisfying your conditions
  $allUsers = $storage->getQuery()
    ->accessCheck(FALSE)
    ->condition('field_tipologia_incarico', $tid) // Usa il TID trovato
    ->condition('status', 1)
    ->condition('field_data_scadenza_incarico', $current_time, '<=')
    ->exists('field_data_scadenza_incarico')
    ->execute();

  // Load all User entities according to their IDs
  $uids = User::loadMultiple($allUsers);
  foreach ($uids as $user) {
    foreach ($user->getRoles() as $role) {
      $user->removeRole($role);
    }
    // Update User
    $user->block();
    // $user->set('status', 0); anche questa istruzione imposto lo stato a BLOCCATO di un UTENTE
    $user->save();

    // Aggiungi logging
    \Drupal::logger('christes')->notice(
      'Utente @username (UID: @uid) bloccato per scadenza incarico.',
      ['@username' => $username, '@uid' => $user->id()]
    );
  }
}

/**
 * Implements hook_form_FORM_ID_alter().
 */
function christes_form_user_register_form_alter(&$form, FormStateInterface $form_state, $form_id) {
  if (isset($form['account']['notify'])) {
    // Notify user by default on account creation.
    $form['account']['notify']['#default_value'] = TRUE;
  }
  // Il nome utente viene generato automaticamente dal modulo email_registration: nasconde il campo.
  $form['account']['name']['#access'] = FALSE;
}

/**
 * Implements hook_form_FORM_ID_alter().
 *
 * Nasconde il campo Nome Utente nel form di MODIFICA profilo.
 */
function christes_form_user_form_alter(&$form, FormStateInterface $form_state, $form_id) {
  $form['account']['name']['#access'] = FALSE;
}

/**
 * Implements hook_user_presave().
 *
 * Normalizza i campi utente prima del salvataggio:
 * - field_nome e field_cognome: prima lettera di ogni parola in maiuscolo (ucwords).
 * - field_codice_fiscale: tutto maiuscolo.
 *
 * Funziona sia da form che da import/API.
 */
function christes_user_presave(Drupal\user\UserInterface $user) {
  // Normalizza field_nome e field_cognome: ucwords multilingua.
  foreach (['field_nome', 'field_cognome'] as $field_name) {
    if ($user->hasField($field_name) && !$user->get($field_name)->isEmpty()) {
      $value = $user->get($field_name)->value;
      // mb_convert_case gestisce correttamente i caratteri accentati italiani.
      $value = mb_convert_case(mb_strtolower($value), MB_CASE_TITLE, 'UTF-8');
      $user->set($field_name, $value);
    }
  }

  // Normalizza field_codice_fiscale: tutto maiuscolo.
  if ($user->hasField('field_codice_fiscale') && !$user->get('field_codice_fiscale')->isEmpty()) {
    $value = $user->get('field_codice_fiscale')->value;
    $user->set('field_codice_fiscale', mb_strtoupper($value, 'UTF-8'));
  }
}
