<?php

use Drupal\Core\Datetime\DrupalDateTime;
use Drupal\user\Entity\User;
use Drupal\Core\Form\FormStateInterface;

/**
 * Implements hook_cron().
 *
 * @throws \Drupal\Core\Entity\EntityStorageException
 */
function christes_cron() {
  // Build Drupal DateTime & set correct format for your query
  $current_time = new DrupalDateTime('now');
  $current_time = $current_time->format('Y-m-d');

  // Trova il TID del termine cercando per nome
  $term_name = 'Tempo determinato'; // Sostituisci con il nome effettivo
  $vocabulary_id = 'tipologia_incarichi'; // ID del vocabolario

  $term_storage = \Drupal::entityTypeManager()->getStorage('taxonomy_term');
  $terms = $term_storage->loadByProperties([
    'name' => $term_name,
    'vid' => $vocabulary_id,
  ]);

  // Se non trovi il termine, esci
  if (empty($terms)) {
    \Drupal::logger('christes')
      ->warning('Termine tassonomico "@name" non trovato.', ['@name' => $term_name]);
    return;
  }

  // Prendi il primo termine trovato
  $term = reset($terms);
  $tid = $term->id();

  $storage = \Drupal::entityTypeManager()->getStorage('user');

  // Get all Users satisfying your conditions
  $allUsers = $storage->getQuery()
    ->accessCheck(FALSE)
    ->condition('field_tipologia_incarico', $tid) // Usa il TID trovato
    ->condition('status', 1)
    ->condition('field_data_scadenza_incarico', $current_time, '<=')
    ->execute();

  // Load all User entities according to their IDs
  $uids = User::loadMultiple($allUsers);
  foreach ($uids as $user) {
    foreach ($user->getRoles() as $role) {
      $user->removeRole($role);
    }
    // Update User
    $user->block();
    // $user->set('status', 0); anche questa istruzione imposto lo stato a BLOCCATO di un UTENTE
    $user->save();
  }
}

/**
 * Implements hook_form_FORM_ID_alter().
 */
function christes_form_user_register_form_alter(&$form, FormStateInterface $form_state, $form_id) {
  if (isset($form['account']['notify'])) {
    // Notify user by default on account creation.
    $form['account']['notify']['#default_value'] = TRUE;
  }

  // Callback di validazione per impostare il nome utente automatico.
  $form['#validate'][] = 'christes_user_register_form_set_username';
}

/**
 * Callback di validazione: imposta il nome utente da field_nome + field_cognome.
 *
 * Genera un nome utente nel formato "nome.cognome" (minuscolo, senza spazi).
 * Se il nome utente esiste già, aggiunge un suffisso numerico progressivo.
 */
function christes_user_register_form_set_username(&$form, FormStateInterface $form_state) {
  $nome    = trim($form_state->getValue(['field_nome', 0, 'value']) ?? '');
  $cognome = trim($form_state->getValue(['field_cognome', 0, 'value']) ?? '');

  if (empty($nome) || empty($cognome)) {
    // Se i campi non sono ancora compilati, non fare nulla.
    return;
  }

  // Normalizza: minuscolo, rimuovi spazi interni, sostituisci caratteri accentati.
  $nome    = _christes_normalize_username_part($nome);
  $cognome = _christes_normalize_username_part($cognome);

  $base_username = $nome . '.' . $cognome;

  // Trova un nome utente univoco aggiungendo suffisso numerico se necessario.
  $username = $base_username;
  $counter  = 2;
  while (_christes_username_exists($username)) {
    $username = $base_username . $counter;
    $counter++;
  }

  $form_state->setValue(['account', 'name'], $username);
}

/**
 * Normalizza una parte del nome utente: minuscolo, no spazi, traslittera accenti.
 */
function _christes_normalize_username_part(string $value): string {
  // Traslitterazione caratteri accentati italiani più comuni.
  $map = [
    'à' => 'a', 'á' => 'a', 'â' => 'a', 'ã' => 'a', 'ä' => 'a',
    'è' => 'e', 'é' => 'e', 'ê' => 'e', 'ë' => 'e',
    'ì' => 'i', 'í' => 'i', 'î' => 'i', 'ï' => 'i',
    'ò' => 'o', 'ó' => 'o', 'ô' => 'o', 'õ' => 'o', 'ö' => 'o',
    'ù' => 'u', 'ú' => 'u', 'û' => 'u', 'ü' => 'u',
    'ý' => 'y', 'ÿ' => 'y',
    'ñ' => 'n', 'ç' => 'c',
  ];
  $value = strtr(mb_strtolower($value), $map);

  // Rimuovi qualsiasi carattere non alfanumerico (spazi, apostrofi, trattini...).
  $value = preg_replace('/[^a-z0-9]/', '', $value);

  return $value;
}

/**
 * Verifica se un nome utente è già in uso.
 */
function _christes_username_exists(string $username): bool {
  return (bool) \Drupal::entityQuery('user')
    ->accessCheck(FALSE)
    ->condition('name', $username)
    ->range(0, 1)
    ->execute();
}
